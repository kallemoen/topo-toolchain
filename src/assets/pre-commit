#!/usr/bin/env bash
# Topo drift guard — installed by `topo init`.
# Blocks the commit when the system map has drifted from the code.
# Real emergency? Bypass with: git commit --no-verify
#
# Resolves the `topo` CLI in this order: $TOPO_BIN, a `topo` on PATH, a local
# devDependency (npx --no-install), then zero-install straight from GitHub.

run_topo() {
  if [ -n "$TOPO_BIN" ]; then
    $TOPO_BIN "$@"
  elif command -v topo >/dev/null 2>&1; then
    topo "$@"
  elif npx --no-install topo --version >/dev/null 2>&1; then
    npx --no-install topo "$@"
  else
    npx --yes github:kallemoen/topo-toolchain "$@"
  fi
}

if ! run_topo check; then
  echo ""
  echo "topo: the system map has drifted from the code. Fix it with:"
  echo "      update system.topo, then 'topo approve', until 'topo check' is green"
  echo "      — or bypass this one commit with: git commit --no-verify"
  exit 1
fi
